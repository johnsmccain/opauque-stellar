# Stellar network: testnet | futurenet | mainnet | local
VITE_STELLAR_NETWORK=testnet

# Soroban RPC (optional; defaults to public testnet RPC)
# VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon (optional)
# VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban contract IDs (set after deploying contracts/)
# Production builds require network-specific IDs for the active VITE_STELLAR_NETWORK.
# Example for testnet:
# VITE_TESTNET_STEALTH_REGISTRY_CONTRACT=
# VITE_TESTNET_STEALTH_ANNOUNCER_CONTRACT=
# VITE_TESTNET_GROTH16_VERIFIER_CONTRACT=
# VITE_TESTNET_REPUTATION_VERIFIER_CONTRACT=
# VITE_TESTNET_SCHEMA_REGISTRY_CONTRACT=
# VITE_TESTNET_ATTESTATION_ENGINE_CONTRACT=

# Legacy unprefixed names are accepted only outside production builds.
# VITE_STEALTH_REGISTRY_CONTRACT=
# VITE_STEALTH_ANNOUNCER_CONTRACT=
# VITE_GROTH16_VERIFIER_CONTRACT=
# VITE_REPUTATION_VERIFIER_CONTRACT=
# VITE_SCHEMA_REGISTRY_CONTRACT=
# VITE_ATTESTATION_ENGINE_CONTRACT=
